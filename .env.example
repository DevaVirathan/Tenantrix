# ============================================================
# Tenantrix — Environment Variables
# Copy this file to .env and fill in real values.
# ============================================================

# ----------------------------------------------------------
# Database
# ----------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=tenantrix
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ----------------------------------------------------------
# Security
# ----------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY="381e195ae3ec16369405e3bac209fa597eba9ceb13500982922973502e6d8fcc"

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ----------------------------------------------------------
# Application
# ----------------------------------------------------------
ENVIRONMENT=development
VERSION=0.1.0
DEBUG=false

# ----------------------------------------------------------
# Rate limiting (requests per minute per IP)
# ----------------------------------------------------------
RATE_LIMIT_PER_MINUTE=60

# ----------------------------------------------------------
# CORS — comma-separated allowed origins
# ----------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ----------------------------------------------------------
# SMTP / Email (Mailhog for local dev)
# ----------------------------------------------------------
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=false
MAIL_FROM_EMAIL=noreply@tenantrix.io
MAIL_FROM_NAME=Tenantrix
FRONTEND_URL=http://localhost:5173
